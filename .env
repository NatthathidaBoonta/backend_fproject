# ====================================================================
# DATABASE CONFIGURATION
# ====================================================================

# Options: 'sqlite' or 'mysql'
DB_DIALECT=sqlite

# SQLite Configuration (Only used if DB_DIALECT=sqlite)
# (Automatically created in backend/database.sqlite)

# MySQL Configuration (Only used if DB_DIALECT=mysql)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=graduation_db

# ====================================================================
# APP CONFIGURATION
# ====================================================================
PORT=5000
ALLOWED_ORIGINS=http://localhost:5173